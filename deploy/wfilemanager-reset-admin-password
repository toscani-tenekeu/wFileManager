#!/usr/bin/env bash
set -Eeuo pipefail

[[ "${EUID:-$(id -u)}" -eq 0 ]] || { echo "Run this command as root." >&2; exit 1; }

ENV_FILE="${WFILEMANAGER_ENV_FILE:-/etc/wfilemanager/wfilemanager.env}"
KEY_FILE="${WFILEMANAGER_ROOT_RESET_KEY_FILE:-/etc/wfilemanager/root-reset.key}"

[[ -f "$ENV_FILE" ]] || { echo "Missing $ENV_FILE" >&2; exit 1; }

set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

DATABASE_MODE="${WFILEMANAGER_DATABASE_MODE:-supabase}"
USERNAME="${1:-}"

read -rsp "New administrator password: " NEW_PASSWORD
echo
read -rsp "Confirm new password: " CONFIRM_PASSWORD
echo

[[ "$NEW_PASSWORD" == "$CONFIRM_PASSWORD" ]] || { echo "Passwords do not match." >&2; exit 1; }

POLICY_ERROR="$(printf '%s' "$NEW_PASSWORD" | python3 -c '
import re, sys
password = sys.stdin.read()
if len(password) < 12: print("Password must contain at least 12 characters.")
elif not re.fullmatch(r"[A-Za-z0-9]+", password): print("Password may contain only uppercase letters, lowercase letters and numbers.")
elif not re.search(r"[A-Z]", password): print("Password must contain an uppercase letter.")
elif not re.search(r"[a-z]", password): print("Password must contain a lowercase letter.")
elif not re.search(r"[0-9]", password): print("Password must contain a number.")
elif re.search(r"(.)\1", password): print("Password must not contain identical consecutive characters.")
')"
[[ -z "$POLICY_ERROR" ]] || { echo "$POLICY_ERROR" >&2; exit 1; }

cleanup() {
  unset NEW_PASSWORD CONFIRM_PASSWORD ROOT_TOKEN PAYLOAD WFM_PASSWORD WFM_USERNAME
}
trap cleanup EXIT

if [[ "$DATABASE_MODE" == "sqlite" ]]; then
  DB_PATH="${WFILEMANAGER_SQLITE_PATH:-/var/lib/wfilemanager/wfilemanager.db}"
  [[ -f "$DB_PATH" ]] || { echo "SQLite database was not found at $DB_PATH" >&2; exit 1; }

  WFM_DB_PATH="$DB_PATH" WFM_USERNAME="$USERNAME" WFM_PASSWORD="$NEW_PASSWORD" node --input-type=module <<'NODE'
import { randomBytes, scryptSync } from "node:crypto";
import { DatabaseSync } from "node:sqlite";

const db = new DatabaseSync(process.env.WFM_DB_PATH);
const requested = (process.env.WFM_USERNAME || "").trim().toLowerCase();
const admins = db.prepare("SELECT id, username FROM wfm_users WHERE is_admin = 1 ORDER BY username COLLATE NOCASE").all();
const target = requested
  ? admins.find((user) => String(user.username).toLowerCase() === requested)
  : admins.length === 1 ? admins[0] : null;

if (!target) {
  const names = admins.map((user) => user.username).join(", ");
  console.error(names ? `Specify an administrator username: ${names}` : "No administrator account exists.");
  process.exit(2);
}

const salt = randomBytes(16).toString("hex");
const hash = scryptSync(process.env.WFM_PASSWORD, Buffer.from(salt, "hex"), 64).toString("hex");
const now = new Date().toISOString();
db.exec("BEGIN IMMEDIATE");
try {
  db.prepare("UPDATE wfm_users SET password_hash = ?, password_salt = ?, must_change_password = 0, updated_at = ? WHERE id = ?")
    .run(hash, salt, now, target.id);
  db.prepare("DELETE FROM wfm_sessions WHERE user_id = ?").run(target.id);
  db.prepare("INSERT INTO wfm_audit_logs(user_id, username, action, target, result, created_at) VALUES(?, ?, 'root_password_reset', ?, 'success', ?)")
    .run(target.id, target.username, target.username, now);
  db.exec("COMMIT");
} catch (error) {
  db.exec("ROLLBACK");
  throw error;
}
console.log(`Password reset completed for ${target.username}.`);
console.log("All existing wFileManager sessions were revoked.");
NODE
  exit 0
fi

[[ -f "$KEY_FILE" ]] || { echo "Missing $KEY_FILE. Reinstall wFileManager first." >&2; exit 1; }
SUPABASE_URL="${WFILEMANAGER_SUPABASE_URL:-${VITE_SUPABASE_URL:-}}"
INSTANCE_KEY="${WFILEMANAGER_INSTANCE_KEY:-${VITE_WFILEMANAGER_INSTANCE_KEY:-}}"
RESET_URL="${SUPABASE_URL%/}/functions/v1/wfilemanager-root-reset-api"
ROOT_TOKEN="$(tr -d '\r\n' <"$KEY_FILE")"

[[ -n "$SUPABASE_URL" && -n "$INSTANCE_KEY" && -n "$ROOT_TOKEN" ]] || { echo "Managed Supabase recovery is not configured." >&2; exit 1; }

PAYLOAD="$(WFM_PASSWORD="$NEW_PASSWORD" WFM_USERNAME="$USERNAME" python3 - <<'PY'
import json, os
payload = {"password": os.environ["WFM_PASSWORD"]}
username = os.environ.get("WFM_USERNAME", "").strip()
if username: payload["username"] = username
print(json.dumps(payload, separators=(",", ":")))
PY
)"
RESPONSE_FILE="$(mktemp)"
trap 'rm -f "$RESPONSE_FILE"; cleanup' EXIT
HTTP_STATUS="$(curl -sS --connect-timeout 10 --max-time 60 -o "$RESPONSE_FILE" -w '%{http_code}' \
  -X POST "$RESET_URL" -H 'Content-Type: application/json' \
  -H "x-wfilemanager-instance: $INSTANCE_KEY" -H "x-wfilemanager-root-token: $ROOT_TOKEN" --data "$PAYLOAD")"

if [[ "$HTTP_STATUS" != "200" ]]; then
  ERROR_MESSAGE="$(python3 - "$RESPONSE_FILE" <<'PY'
import json, sys
try:
    payload = json.load(open(sys.argv[1], encoding="utf-8"))
    message = payload.get("error") or "Password reset failed"
    if payload.get("administrators"): message += ". Administrators: " + ", ".join(payload["administrators"])
    print(message)
except Exception: print("Password reset failed")
PY
)"
  echo "$ERROR_MESSAGE (HTTP $HTTP_STATUS)" >&2
  exit 1
fi

RESET_USERNAME="$(python3 - "$RESPONSE_FILE" <<'PY'
import json, sys
print(json.load(open(sys.argv[1], encoding="utf-8")).get("username", "administrator"))
PY
)"
echo "Password reset completed for $RESET_USERNAME."
echo "All existing wFileManager sessions were revoked."
