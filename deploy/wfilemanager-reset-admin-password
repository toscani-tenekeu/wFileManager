#!/usr/bin/env bash
set -Eeuo pipefail

if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
  echo "Run this command as root." >&2
  exit 1
fi

ENV_FILE="${WFILEMANAGER_ENV_FILE:-/etc/wfilemanager/wfilemanager.env}"
KEY_FILE="${WFILEMANAGER_ROOT_RESET_KEY_FILE:-/etc/wfilemanager/root-reset.key}"

[[ -f "$ENV_FILE" ]] || { echo "Missing $ENV_FILE" >&2; exit 1; }
[[ -f "$KEY_FILE" ]] || { echo "Missing $KEY_FILE. Reinstall or enroll the root reset command first." >&2; exit 1; }

set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

SUPABASE_URL="${WFILEMANAGER_SUPABASE_URL:-${VITE_SUPABASE_URL:-}}"
INSTANCE_KEY="${WFILEMANAGER_INSTANCE_KEY:-${VITE_WFILEMANAGER_INSTANCE_KEY:-}}"
RESET_URL="${SUPABASE_URL%/}/functions/v1/wfilemanager-root-reset-api"
ROOT_TOKEN="$(tr -d '\r\n' < "$KEY_FILE")"
USERNAME="${1:-}"

[[ -n "$SUPABASE_URL" ]] || { echo "Supabase URL is not configured." >&2; exit 1; }
[[ -n "$INSTANCE_KEY" ]] || { echo "wFileManager instance key is not configured." >&2; exit 1; }
[[ -n "$ROOT_TOKEN" ]] || { echo "The root reset token is empty." >&2; exit 1; }

read -rsp "New administrator password: " NEW_PASSWORD
echo
read -rsp "Confirm new password: " CONFIRM_PASSWORD
echo

if [[ "$NEW_PASSWORD" != "$CONFIRM_PASSWORD" ]]; then
  echo "Passwords do not match." >&2
  exit 1
fi

POLICY_ERROR="$(printf '%s' "$NEW_PASSWORD" | python3 -c '
import re, sys
password = sys.stdin.read()
error = None
if len(password) < 12:
    error = "Password must contain at least 12 characters."
elif not re.fullmatch(r"[A-Za-z0-9]+", password):
    error = "Password may contain only uppercase letters, lowercase letters and numbers."
elif not re.search(r"[A-Z]", password):
    error = "Password must contain an uppercase letter."
elif not re.search(r"[a-z]", password):
    error = "Password must contain a lowercase letter."
elif not re.search(r"[0-9]", password):
    error = "Password must contain a number."
elif re.search(r"(.)\1", password):
    error = "Password must not contain identical consecutive characters."
print(error or "")
')"

if [[ -n "$POLICY_ERROR" ]]; then
  echo "$POLICY_ERROR" >&2
  exit 1
fi

PAYLOAD="$(WFM_PASSWORD="$NEW_PASSWORD" WFM_USERNAME="$USERNAME" python3 - <<'PY'
import json, os
payload = {"password": os.environ["WFM_PASSWORD"]}
username = os.environ.get("WFM_USERNAME", "").strip()
if username:
    payload["username"] = username
print(json.dumps(payload, separators=(",", ":")))
PY
)"

RESPONSE_FILE="$(mktemp)"
cleanup() {
  rm -f -- "$RESPONSE_FILE"
  unset NEW_PASSWORD CONFIRM_PASSWORD ROOT_TOKEN PAYLOAD WFM_PASSWORD WFM_USERNAME
}
trap cleanup EXIT

HTTP_STATUS="$(curl -sS \
  --connect-timeout 10 \
  --max-time 60 \
  -o "$RESPONSE_FILE" \
  -w '%{http_code}' \
  -X POST "$RESET_URL" \
  -H 'Content-Type: application/json' \
  -H "x-wfilemanager-instance: $INSTANCE_KEY" \
  -H "x-wfilemanager-root-token: $ROOT_TOKEN" \
  --data "$PAYLOAD")"

if [[ "$HTTP_STATUS" != "200" ]]; then
  ERROR_MESSAGE="$(python3 - "$RESPONSE_FILE" <<'PY'
import json, sys
try:
    payload = json.load(open(sys.argv[1], encoding="utf-8"))
    message = payload.get("error") or "Password reset failed"
    admins = payload.get("administrators")
    if admins:
        message += ". Administrators: " + ", ".join(admins)
    print(message)
except Exception:
    print("Password reset failed")
PY
)"
  echo "$ERROR_MESSAGE (HTTP $HTTP_STATUS)" >&2
  exit 1
fi

RESET_USERNAME="$(python3 - "$RESPONSE_FILE" <<'PY'
import json, sys
payload = json.load(open(sys.argv[1], encoding="utf-8"))
print(payload.get("username", "administrator"))
PY
)"

echo "Password reset completed for $RESET_USERNAME."
echo "All existing wFileManager sessions were revoked."
