[Unit]
Description=wFileManager managed Supabase heartbeat
After=network-online.target wfilemanager.service
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/lib/wfilemanager/heartbeat.sh
User=root
Group=root
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/lib/wfilemanager
ProtectHome=read-only
